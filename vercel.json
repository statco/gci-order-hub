{
  "outputDirectory": ".",
  "functions": {
    "api/order-router.ts":        { "maxDuration": 30  },
    "api/authorize-order.ts":     { "maxDuration": 30  },
    "api/walmart-sync.ts":        { "maxDuration": 300 },
    "api/walmart-order-sync.ts":  { "maxDuration": 300 },
    "api/walmart-item-feed.ts":   { "maxDuration": 300 },
    "api/walmart-feed-status.ts": { "maxDuration": 10  },
    "api/walmart-ship.ts":        { "maxDuration": 60  },
    "api/getPendingOrders.ts":    { "maxDuration": 30  },
    "api/ct-tracking-parser.ts":  { "maxDuration": 60  }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/walmart-sync",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/walmart-order-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/ct-tracking-parser",
      "schedule": "*/30 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
