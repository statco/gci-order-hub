{
  "outputDirectory": ".",
  "functions": {
    "api/order-router.ts":        { "maxDuration": 30  },
    "api/authorize-order.ts":     { "maxDuration": 30  },
    "api/walmart-sync.ts":         { "maxDuration": 300 },
    "api/walmart-reconcile.ts":    { "maxDuration": 300 },
    "api/cost-integrity-audit.ts": { "maxDuration": 60  },
    "api/walmart-price-audit.ts":  { "maxDuration": 300 },
    "api/walmart-price-correct.ts":{ "maxDuration": 300 },
    "api/walmart-order-sync.ts":  { "maxDuration": 300 },
    "api/walmart-item-feed.ts":   { "maxDuration": 300 },
    "api/walmart-feed-status.ts": { "maxDuration": 10  },
    "api/walmart-feed-diag.ts":   { "maxDuration": 10  },
    "api/walmart-ship.ts":        { "maxDuration": 60  },
    "api/getPendingOrders.ts":    { "maxDuration": 30  },
    "api/ct-tracking-parser.ts":  { "maxDuration": 60  },
    "api/walmart-zero.ts":         { "maxDuration": 60  },
    "api/walmart-orphan-sweep.ts": { "maxDuration": 300 },
    "api/walmart-retire.ts":       { "maxDuration": 300 }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    { "path": "/api/walmart-sync?mode=listed&offset=0&limit=300",    "schedule": "0 9 * * *"  },
    { "path": "/api/walmart-sync?mode=listed&offset=300&limit=300",  "schedule": "5 9 * * *"  },
    { "path": "/api/walmart-sync?mode=listed&offset=600&limit=300",  "schedule": "10 9 * * *" },
    { "path": "/api/walmart-sync?mode=listed&offset=900&limit=300",  "schedule": "15 9 * * *" },
    { "path": "/api/walmart-sync?mode=listed&offset=1200&limit=300", "schedule": "20 9 * * *" },
    { "path": "/api/walmart-sync?mode=listed&offset=1500&limit=300", "schedule": "25 9 * * *" },
    { "path": "/api/walmart-sync?mode=listed&offset=1800&limit=300", "schedule": "30 9 * * *" },
    { "path": "/api/walmart-sync?mode=listed&offset=2100&limit=300", "schedule": "35 9 * * *" },
    { "path": "/api/walmart-sync?mode=listed&offset=2400&limit=300", "schedule": "40 9 * * *" },
    { "path": "/api/walmart-sync?mode=listed&offset=2700&limit=300", "schedule": "45 9 * * *" },
    { "path": "/api/walmart-sync?mode=listed&offset=3000&limit=300", "schedule": "50 9 * * *" },
    { "path": "/api/walmart-order-sync",                             "schedule": "*/15 * * * *" },
    { "path": "/api/cost-integrity-audit",                           "schedule": "0 9 * * *"   },
    { "path": "/api/ct-tracking-parser",                             "schedule": "*/30 * * * *" },
    { "path": "/api/walmart-orphan-sweep?dryRun=false",              "schedule": "0 11 * * *"  }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
