# ═══════════════════════════════════════════════════════════════
# GCI Order Hub — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to source control.
# ═══════════════════════════════════════════════════════════════

# ── SHOPIFY ──────────────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=gcitires.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# ── ORDER ROUTER ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ORDER_ROUTER_SECRET=
APP_BASE_URL=

# ── NOTIFICATIONS — TELEGRAM ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── NOTIFICATIONS — EMAIL (Resend) ───────────────────────────────────────
RESEND_API_KEY=
NOTIFY_EMAIL_TO=owner@gcitires.com
NOTIFY_EMAIL_FROM=GCI Orders <orders@updates.gcitires.ca>

# ── CJ DROPSHIPPING (inactive — Nuproz discontinued) ──────────────────────
CJ_API_KEY=

# ── WALMART MARKETPLACE ──────────────────────────────────────────────────
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=
WALMART_BASE_URL=https://marketplace.walmartapis.com

# ── GOOGLE SHEETS (Walmart order log) ──────────────────────────────────
# Spreadsheet ID from: https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
WALMART_ORDER_LOG_SHEET_ID=
# Full service account key JSON as a single-line string.
# Grant the service account Editor access to the spreadsheet.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── GMAIL (CT invoice tracking parser) ───────────────────────────────
# OAuth2 credentials for reading the GCI inbox to find CT shipping invoices.
# Setup: Google Cloud Console → APIs → Gmail API → OAuth 2.0 Client IDs
# Scopes needed: https://www.googleapis.com/auth/gmail.modify
# Get refresh token via OAuth playground: https://developers.google.com/oauthplayground
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
