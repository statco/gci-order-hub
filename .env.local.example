# ═══════════════════════════════════════════════════════════════
# GCI Order Hub — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to source control.
# ═══════════════════════════════════════════════════════════════

# ── SHOPIFY ──────────────────────────────────────────────────────
# Your gcitires.com store identifier (no https://, no trailing slash)
SHOPIFY_STORE_DOMAIN=gcitires.myshopify.com

# Admin API token — Shopify Admin → Apps → Private apps (or custom app)
# Scopes needed: read_products, read_inventory
SHOPIFY_ADMIN_API_TOKEN=

# Webhook secret — copy from the webhook you create in:
#   Shopify Admin → Settings → Notifications → Webhooks
#   Event: Order payment  |  URL: https://<your-domain>/api/order-router
SHOPIFY_WEBHOOK_SECRET=

# ── ORDER ROUTER ─────────────────────────────────────────────────
# 32+ char random string used to sign "Authorize Payment" links.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ORDER_ROUTER_SECRET=

# Base URL for authorize links (auto-detected from VERCEL_URL in production).
# Set for local development: http://localhost:3000
APP_BASE_URL=

# ── NOTIFICATIONS — TELEGRAM (primary) ───────────────────────────
# 1. Message @BotFather on Telegram → /newbot → save the token
# 2. Start a conversation with your new bot
# 3. Visit: https://api.telegram.org/bot<TOKEN>/getUpdates → find "chat":{"id":...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── NOTIFICATIONS — EMAIL FALLBACK (Resend) ───────────────────────
# Dashboard: https://resend.com
RESEND_API_KEY=

# Your email address where order alerts should be sent
NOTIFY_EMAIL_TO=owner@gcitires.com

# Sender identity (must be a verified domain in Resend)
NOTIFY_EMAIL_FROM=GCI Orders <orders@updates.gcitires.ca>

# ── CJ DROPSHIPPING (Nuproz / NUPROZ- SKUs) ─────────────────────
# Dashboard: https://app.cjdropshipping.com → Developer → API Keys
#
# Option A — API Key (preferred, never expires)
CJ_API_KEY=

# Option B — Email + Password (token auto-refreshed every 55 min)
# CJ_EMAIL=
# CJ_PASSWORD=

# ── WALMART MARKETPLACE ──────────────────────────────────────────
# Dashboard: https://developer.walmart.com → My Account → Credentials
# For Walmart Canada, use the same base URL — credentials set the market.
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=

# Override the base URL if Walmart publishes a separate Canada endpoint
# Default (US + Canada): https://marketplace.walmartapis.com
WALMART_BASE_URL=https://marketplace.walmartapis.com
